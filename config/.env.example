# labHandler 集中配置模板
# 用法：cp config/.env.example config/.env，然后填入实际值

# ─── Paratera LLM API ──────────────────────────────────────────────
PARATERA_API_KEY=sk-xxx_replace_me
PARATERA_BASE_URL=https://llmapi.paratera.com/v1/
PARATERA_LLM_MODEL=DeepSeek-V4-Pro
PARATERA_EMBEDDING_MODEL=GLM-Embedding-3
PARATERA_REASONING_EFFORT=max

# ─── LLM Provider 切换 ─────────────────────────────────────────────
LLM_PROVIDER=paratera

# ─── Ollama 本地兜底（可选） ───────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_EMBEDDING_MODEL=bge-m3

# ─── AIO Sandbox 容器 ─────────────────────────────────────────────
AIO_SANDBOX_IMAGE=enterprise-public-cn-beijing.cr.volces.com/vefaas-public/all-in-one-sandbox:latest
AIO_SANDBOX_PORT=8080
AIO_SANDBOX_MCP_URL=http://127.0.0.1:8080/mcp
# 启动 cli.py 时自动拉起容器（未跑时 docker run / 已停时 docker start）；false=手动管
LAB_AUTOSTART_SANDBOX=true

# ─── 存储路径 ─────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./.labhandler_data/chroma
CHROMA_COLLECTION_NAME=task_archive_glm_embedding_3
MEMORY_DB_PATH=./.labhandler_data/memory.db
PROFILE_PATH=./profile/me.yaml
SKILLS_DIR=./skills
WORKSPACE_DIR=./workspace

# ─── LLM 缓存（langchain InMemoryCache 全局钩子，进程内 dict） ─────
# 同进程内同 prompt 命中省 API 费；进程退出即清，不写盘
# LLM_CACHE_ENABLED=false 整体关闭；调试不希望复用历史响应时关掉
LLM_CACHE_ENABLED=true

# ─── Agent 行为参数 ──────────────────────────────────────────────
MAX_REACT_ITER=6
MAX_REPLAN_ITER=2
# Planner 每次从归档检索的经验卡片数量
PLANNER_ARCHIVE_TOP_K=3

# ─── 网络代理（可选，DDG 检索用；不需要代理留空） ─────────────────
PROXY=
SEARCH_MAX_RETRIES=2
SEARCH_RETRY_DELAY=3
